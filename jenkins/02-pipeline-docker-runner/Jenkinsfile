// ═══════════════════════════════════════════════════════════════════════════
// Jenkinsfile — Ejercicio 2: build runner sobre imagen Docker de Gradle
// ═══════════════════════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════

pipeline {

    agent {
        docker {
            image 'gradle:6.6.1-jre14-openj9'
            args '-u root:root -v gradle-cache:/home/gradle/.gradle'
        }
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        SRC_DIR = '03-cd/exercises/jenkins-resources/calculator'
        GRADLE_OPTS = '-Dorg.gradle.daemon=false'
        GRADLE_USER_HOME = '/home/gradle/.gradle'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url:    'https://github.com/Lemoncode/bootcamp-devops-lemoncode.git'
            }
        }

        stage('Compile') {
            steps {
                dir("${env.SRC_DIR}") {
                    sh 'gradle compileJava'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${env.SRC_DIR}") {
                    sh 'gradle test'
                }
            }
            post {
                always {
                    junit testResults: "${env.SRC_DIR}/build/test-results/test/*.xml",
                          allowEmptyResults: true
                }
            }
        }
    }

    post {
        success { echo 'Pipeline OK — runner Docker + Gradle 6.6.1 funcional' }
        failure { echo 'Pipeline KO — revisa logs y permisos del socket Docker' }
        always  { echo "Build #${env.BUILD_NUMBER} en ${currentBuild.durationString}" }
    }
}
